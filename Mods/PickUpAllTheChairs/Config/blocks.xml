<RamblingMan>

<!-- 2.5.1.1 -->

<!-- ***Pick up coneConstruction. -->


 	<append xpath="/blocks/block[@name='coneConstruction']">
		<property name="CanPickup" value="true"/>
		<property name="Stacknumber" value="10"/>
		<property name="Weight" value="10"/>
	</append>

<!-- ***Pick up horseshoe_01, 02, 03. -->

	<append xpath="/blocks/block[starts-with(@name,'horseshoe_0')]">
		<property name="CanPickup" value="true" />
		<property name="Stacknumber" value="25"/>
		<property name="Weight" value="10"/>
	</append>	

<!-- ***Pick up flags. Not scrappable. -->
	<append xpath="/blocks/block[@name='flagWallHungUSA' or @name='flagTopWallHungUSA']">
		<property name="CanPickup" value="true" />
 		<property name="Stacknumber" value="10"/>
	</append>	


<!-- ***Pick up desk lamps and table lamps. Not scrappable. -->
	<append xpath="/blocks/block[@name='deskLampLight' or @name='deskLampLight02White' or @name='tableLampLight01White']">
		<property name="CanPickup" value="true" />
 		<property name="Stacknumber" value="10"/>
	</append>	


<!-- ***Pick up lanterns. -->
<!-- Does not work if OcbLightEnablerPOI enabled. -->
<!-- Check TakeDelay -1 on some light sources) -->

	<append xpath="/blocks/block[starts-with(@name,'lantern')]">
		<property name="CanPickup" value="true" />
 		<property name="Stacknumber" value="10"/>
	</append>	

<!-- Needs to have a blank class to allow the light to turn on automatically when placed -->
	<append xpath="/blocks/block[starts-with(@name,'lanternOld_0')]">
		<property name="Class" value=""/>
		<property name="Light" value="0.5"/>
	</append>
	
	

<!-- lanternDecorLightWhite -->

<!-- Change class to empty -->
	<setattribute xpath="/blocks/block[ @name='lanternDecorLightWhite']/property[@name='Class']" name="value"></setattribute>
<!-- append light value -->
	<append xpath="/blocks/block[ @name='lanternDecorLightWhite']">
		<property name="Light" value="0.5"/>
	</append>


