<RamblingMan>

<!-- 2.5.1.0 -->

<!-- Remove vanilla item rewards (questRewardPipePistolBundle etc.) -->

<remove xpath="/quests/quest[@id='intro_buried_supplies']/reward[@type='Item']" />

<!-- Set tier 1 melee weapon bundles as rewards for completing the intro_buried_supplies quest. 
NOTE: The Pipe Baton (T0) bundle is available in vanilla. The Robotic Sledge isn't really used as a held weapon. The Stun Baton is a T2 weapon.
 -->
<append xpath="/quests/quest[@id='intro_buried_supplies']">
		<reward type="Item" id="questRewardmeleeWpnClubT1BaseballBatBundle" ischosen="true" value="1"/>
		<reward type="Item" id="questRewardmeleeWpnBladeT1HuntingKnifeBundle" ischosen="true" value="1"/>
		<reward type="Item" id="questRewardmeleeWpnKnucklesT1IronKnucklesBundle" ischosen="true" value="1"/>
		<reward type="Item" id="questRewardmeleeWpnSledgeT1IronSledgehammerBundle" ischosen="true" value="1"/>
		<reward type="Item" id="questRewardmeleeWpnSpearT1IronSpearBundle" ischosen="true" value="1"/>
</append>

<!-- If Extreme Quick Start (https://www.nexusmods.com/7daystodie/mods/8856) or Skip Intro Buried Supplies (https://www.nexusmods.com/7daystodie/mods/8764) are installed, the rewards need to be updated for the quest_whiteRiverCitizen1 quest. -->
<conditional>
<if cond="mod_loaded('ExtremeQuickStartTraderRekt') or mod_loaded('ExtremeQuickStartTraderJen') or mod_loaded('ExtremeQuickStartTraderBob') or mod_loaded('ExtremeQuickStartTraderHugh') or mod_loaded('ExtremeQuickStartTraderJoel') or mod_loaded('RamblingManSkipIntroBuriedSupplies')">

<remove xpath="quests/quest[@id='quest_whiteRiverCitizen1']/reward[@type='Item']" />

<append xpath="/quests/quest[@id='quest_whiteRiverCitizen1']">
		<reward type="Item" id="questRewardmeleeWpnClubT1BaseballBatBundle" ischosen="true" value="1"/>
		<reward type="Item" id="questRewardmeleeWpnBladeT1HuntingKnifeBundle" ischosen="true" value="1"/>
		<reward type="Item" id="questRewardmeleeWpnKnucklesT1IronKnucklesBundle" ischosen="true" value="1"/>
		<reward type="Item" id="questRewardmeleeWpnSledgeT1IronSledgehammerBundle" ischosen="true" value="1"/>
		<reward type="Item" id="questRewardmeleeWpnSpearT1IronSpearBundle" ischosen="true" value="1"/>
</append>

</if>
</conditional>


</RamblingMan>		