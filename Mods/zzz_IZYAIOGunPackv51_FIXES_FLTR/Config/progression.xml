<append xpath="/progression/crafting_skills/crafting_skill[@name='craftingRifles']/display_entry[@item='gunRifleT3SniperRifle']">
	<unlock_entry item="ammo762mmExplosiveFragmentations" unlock_tier="1" tags="ammo762mmExplosiveFragmentations"/>
</append>

<append xpath="/progression/crafting_skills/crafting_skill[@name='craftingRifles']/display_entry[@item='gunRifleT3SniperRifle']">
	<unlock_entry item="ammo762mmExplosiveFragmentationsBundle" unlock_tier="1" tags="ammo762mmExplosiveFragmentationsBundle"/>
</append>

<append xpath="/progression/crafting_skills/crafting_skill[@name='craftingRifles']/effect_group">
	<passive_effect name="RecipeTagUnlocked" operation="base_set" level="61,100" value="1" tags="ammo762mmExplosiveFragmentations,ammo762mmExplosiveFragmentationsBundle"/>
</append>

<append xpath="/progression/crafting_skills/crafting_skill[@name='craftingRifles']/effect_group">
	<passive_effect name="RecipeTagUnlocked" operation="base_set" level="61,100" value="1" tags="ammo762mmExplosiveFragmentationsBundle"/>
</append>

</if>
</conditional>

</RamblingMan>


